# アプリ
PORT=8080
ENV=development

# DB 接続（Render など本番ではこちらを推奨）
DATABASE_URL=user:password@tcp(localhost:3306)/mydb?charset=utf8mb4&parseTime=true&loc=Local

# DB 接続（DATABASE_URL がない場合のフォールバック）
DB_USER=user
DB_PASS=password
DB_NAME=mydb
DB_HOST=localhost
DB_PORT=3306

# mysql サービス用設定（docker-compose.yml の environment と同じキー）
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=mydb
MYSQL_USER=user
MYSQL_PASSWORD=password